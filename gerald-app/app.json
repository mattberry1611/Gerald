{
  "expo": {
    "name": "Gerald",
    "slug": "gerald-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/gerald_logo.png",
    "splash": {
      "image": "./assets/gerald_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "android": {
      "package": "com.matt.gerald",
      "minSdkVersion": 26,
      "permissions": [
        "RECORD_AUDIO",
        "INTERNET",
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS",
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#00c896"
        }
      ],
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "Gerald needs microphone access for push-to-talk."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "gerald",
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
